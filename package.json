{
  "name": "leet-container-dashboard",
  "version": "1.1.0",
  "private": true,
  "author": {
    "name": "Eldar Gerfanov"
  },
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run copy-vendor && kill-port 3000 && bun run src/index.ts",
    "dev": "bun run copy-vendor && kill-port 3000 && bun --watch src/index.ts",
    "test": "vitest run --no-file-parallelism",
    "docker-dev": "bun x docker compose -f docker-compose.dev.yml up --build",
    "tag": "bun run scripts/git-tag.ts && bun run scripts/git-tag-push.ts",
    "copy-vendor": "bun run scripts/copy-vendor.ts"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.8",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "joi": "^18.2.1",
    "multer": "^2.1.1",
    "ssh2": "^1.17.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.7.0",
    "@types/ssh2": "^1.15.5",
    "@types/supertest": "^7.2.0",
    "kill-port": "^2.0.1",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
